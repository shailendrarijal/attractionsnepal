# Supabase — get from Project Settings → Database → Connection string
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# Supabase — get from Project Settings → API
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string"

# Admin credentials (bcrypt hash of your password)
# Generate hash: node -e "const b=require('bcryptjs');b.hash('yourpassword',10).then(console.log)"
ADMIN_EMAIL="admin@attractionsnepal.com"
ADMIN_PASSWORD_HASH="$2b$10$..."

# Allowed frontend origin
FRONTEND_URL="http://localhost:5173"

NODE_ENV="development"
PORT=3000
