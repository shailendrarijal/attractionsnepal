generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Category {
  // Religious
  TEMPLE
  MONASTERY
  STUPA

  // Historical & Cultural
  DURBAR_PALACE
  ARCHAEOLOGICAL
  CULTURAL_VILLAGE

  // Natural — Views
  HILL_VIEWPOINT
  MOUNTAIN_VIEW

  // Natural — Water
  RIVER
  WATERFALL
  LAKE
  HOT_SPRING

  // Natural — Land
  CAVE
  NATIONAL_PARK

  // Activity
  TREK_ROUTE
  ADVENTURE_SPORTS
  AMUSEMENT_PARK
}

enum Difficulty {
  EASY        // Day hikes, gentle walks
  MODERATE    // Multi-day, some altitude
  HARD        // High altitude, long days
  EXTREME     // Technical, 8000m peaks etc.
}

enum Province {
  KOSHI
  MADHESH
  BAGMATI
  GANDAKI
  LUMBINI
  KARNALI
  SUDURPASHCHIM
}

enum SectionType {
  WHERE_TO_STAY
  WHERE_TO_EAT
  TOURS_EXPERIENCES
  TRAVEL_TIPS
  NEARBY_PLACES
}

// ─────────────────────────────────────────────
// PLACES — all listing types in one model
// Trek-specific fields are nullable
// ─────────────────────────────────────────────

model Place {
  id       String   @id @default(cuid())
  slug     String   @unique
  name     String
  category Category

  // Content
  summary  String              // 2–3 lines, used in cards & meta
  story    String   @db.Text   // Main editorial, markdown supported

  // Location
  district  String
  province  Province
  lat       Float?
  lng       Float?
  elevation Int?               // metres above sea level

  // Practical info
  entryFee     String?          // "Free" | "NPR 100 foreigners / NPR 50 locals"
  bestSeason   String?          // "Oct–Dec, Mar–May"
  openingHours String?
  howToGetThere String? @db.Text

  // ── Trek-only fields (null for non-trek places) ──────────────────
  trekDays         Int?
  trekDifficulty   Difficulty?
  trekMaxElevation Int?         // metres
  trekDistance     Float?       // km total
  trekStartPoint   String?
  trekEndPoint     String?
  trekHighlights   String[]     // e.g. ["Thorong La Pass", "Annapurna Base Camp"]
  // ────────────────────────────────────────────────────────────────

  // Monetisation hooks
  gygQuery     String?          // GetYourGuide widget search term e.g. "Nuwakot"
  bookingCity  String?          // Booking.com affiliate city e.g. "Nuwakot"

  // Media — stored in Supabase Storage
  heroImage String?
  images    String[]

  // SEO
  seoTitle       String?
  seoDescription String?

  // Publishing
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  sections PlaceSection[]
  tags     PlaceTag[]

  @@index([category])
  @@index([province])
  @@index([district])
  @@index([published])
  @@index([featured])
}

// Flexible content sections per place
// Each section maps to a monetised block on the frontend
model PlaceSection {
  id      String @id @default(cuid())
  placeId String
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)

  type    SectionType
  title   String
  content String      @db.Text    // markdown
  links   Json?                   // [{label, url, type: "affiliate"|"info"|"booking"}]
  order   Int         @default(0)
}

// ─────────────────────────────────────────────
// BLOGS — editorial content
// (itineraries, "best of", seasonal guides etc.)
// ─────────────────────────────────────────────

model Blog {
  id      String @id @default(cuid())
  slug    String @unique
  title   String
  excerpt String

  content   String @db.Text
  heroImage String?
  images    String[]

  // Link back to place listing pages
  relatedPlaceSlugs String[]

  seoTitle       String?
  seoDescription String?

  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tags BlogTag[]

  @@index([published])
}

// ─────────────────────────────────────────────
// TAGS — shared between places and blogs
// ─────────────────────────────────────────────

model Tag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  places PlaceTag[]
  blogs  BlogTag[]
}

model PlaceTag {
  placeId String
  tagId   String
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([placeId, tagId])
}

model BlogTag {
  blogId String
  tagId  String
  blog   Blog   @relation(fields: [blogId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([blogId, tagId])
}
