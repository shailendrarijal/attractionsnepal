generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Category {
  // Religious
  TEMPLE
  MONASTERY
  STUPA

  // Historical & Cultural
  DURBAR_PALACE
  ARCHAEOLOGICAL
  CULTURAL_VILLAGE

  // Natural — Views
  HILL_VIEWPOINT
  MOUNTAIN_VIEW

  // Natural — Water
  RIVER
  WATERFALL
  LAKE
  HOT_SPRING

  // Natural — Land
  CAVE
  NATIONAL_PARK

  // Activity
  TREK_ROUTE
  ADVENTURE_SPORTS
  AMUSEMENT_PARK
}

enum Difficulty {
  EASY        // Day hikes, gentle walks
  MODERATE    // Multi-day, some altitude
  HARD        // High altitude, long days
  EXTREME     // Technical, 8000m peaks etc.
}

enum Province {
  KOSHI
  MADHESH
  BAGMATI
  GANDAKI
  LUMBINI
  KARNALI
  SUDURPASHCHIM
}

enum SectionType {
  WHERE_TO_STAY
  WHERE_TO_EAT
  TOURS_EXPERIENCES
  TRAVEL_TIPS
  NEARBY_PLACES
}

// ─────────────────────────────────────────────
// PLACES — all listing types in one model
// Trek-specific fields are nullable
// ─────────────────────────────────────────────

model Place {
  id       String   @id @default(cuid())
  slug     String   @unique
  name     String
  category Category

  // Content
  summary  String              // 2–3 lines, used in cards & meta
  story    String   @db.Text   // Main editorial, markdown supported

  // Location
  district  String
  province  Province
  lat       Float?
  lng       Float?
  elevation Int?               // metres above sea level

  // Practical info
  entryFee     String?          // "Free" | "NPR 100 foreigners / NPR 50 locals"
  bestSeason   String?          // "Oct–Dec, Mar–May"
  openingHours String?
  howToGetThere String? @db.Text

  // Contact info
  website String?
  phone   String?
  email   String?

  // ── Trek-only fields (null for non-trek places) ──────────────────
  trekDays         Int?
  trekDifficulty   Difficulty?
  trekMaxElevation Int?         // metres
  trekDistance     Float?       // km total
  trekStartPoint   String?
  trekEndPoint     String?
  trekStartLat     Float?       // geocoded start-point coordinates
  trekStartLng     Float?
  trekEndLat       Float?       // geocoded end-point coordinates
  trekEndLng       Float?
  trekHighlights   String[]     // e.g. ["Thorong La Pass", "Annapurna Base Camp"]
  // ────────────────────────────────────────────────────────────────

  // Monetisation hooks
  gygQuery     String?          // GetYourGuide widget search term e.g. "Nuwakot"
  bookingCity  String?          // Booking.com affiliate city e.g. "Nuwakot"

  // Media — stored in Supabase Storage
  heroImage String?
  images    String[]

  // SEO
  seoTitle       String?
  seoDescription String?

  // Publishing
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  sections PlaceSection[]
  tags     PlaceTag[]

  @@index([category])
  @@index([province])
  @@index([district])
  @@index([published])
  @@index([featured])
}

// Flexible content sections per place
// Each section maps to a monetised block on the frontend
model PlaceSection {
  id      String @id @default(cuid())
  placeId String
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)

  type    SectionType
  title   String
  content String      @db.Text    // markdown
  links   Json?                   // [{label, url, type: "affiliate"|"info"|"booking"}]
  order   Int         @default(0)
}

// ─────────────────────────────────────────────
// BLOGS — editorial content
// (itineraries, "best of", seasonal guides etc.)
// ─────────────────────────────────────────────

model Blog {
  id      String @id @default(cuid())
  slug    String @unique
  title   String
  excerpt String

  content   String @db.Text
  heroImage String?
  images    String[]

  // Link back to place listing pages
  relatedPlaceSlugs String[]

  seoTitle       String?
  seoDescription String?

  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tags BlogTag[]

  @@index([published])
}

// ─────────────────────────────────────────────
// TAGS — shared between places and blogs
// ─────────────────────────────────────────────

model Tag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  places  PlaceTag[]
  blogs   BlogTag[]
  stories StoryTag[]
}

model PlaceTag {
  placeId String
  tagId   String
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([placeId, tagId])
}

model BlogTag {
  blogId String
  tagId  String
  blog   Blog   @relation(fields: [blogId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([blogId, tagId])
}

// ─────────────────────────────────────────────
// STORIES — mythological, cultural and spiritual
// narratives distinct from travel blog posts
// ─────────────────────────────────────────────

enum StoryCategory {
  MYTHOLOGY    // Creation myths, cosmic events
  FESTIVAL     // Festival origins and significance
  TRADITION    // Cultural customs and life rituals
  SCRIPTURE    // Epic narratives (Ramayana, Mahabharata)
  DEITY        // Stories of specific gods and goddesses
  PILGRIMAGE   // Sacred sites and their spiritual stories
  RITUAL       // Religious ceremonies and their meaning
}

model Story {
  id       String        @id @default(cuid())
  slug     String        @unique
  title    String
  excerpt  String        // 2–3 sentence teaser shown in cards
  content  String        @db.Text  // Full story in Markdown

  category StoryCategory

  relatedPlaceSlugs String[]
  heroImage         String?

  seoTitle       String?
  seoDescription String?

  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tags StoryTag[]

  @@index([published])
  @@index([category])
}

model StoryTag {
  storyId String
  tagId   String
  story   Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([storyId, tagId])
}

// ─────────────────────────────────────────────
// NEWSLETTER — email subscriber list
// ─────────────────────────────────────────────

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  confirmed Boolean  @default(false)
}
